{
  "name": "agentpassport-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "AgentPassport — every credential your AI agent needs to operate globally.",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10.4"
  },
  "packageManager": "pnpm@10.4.1",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf dist .tsbuildinfo"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "tsup": "^8.0.0",
    "vitest": "^1.6.0"
  }
}
